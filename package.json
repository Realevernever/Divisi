{
  "name": "divisi",
  "version": "0.1.2",
  "description": "Delegate Codex work to frontier-model vendor CLIs.",
  "type": "module",
  "bin": {
    "divisi": "dist/cli.js"
  },
  "files": [
    ".codex-plugin/plugin.json",
    ".mcp.json",
    "dist",
    "docs/cleanup.md",
    "docs/installer.md",
    "docs/worker-registry.md",
    "skills",
    "snippets",
    "workers.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:credentials": "node scripts/check-credentials.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check:credentials",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
